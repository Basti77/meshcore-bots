# meshbot-wetter environment

# Matrix
MATRIX_HOMESERVER=https://matrix.example.org
MATRIX_USER_ID=@meshwetter:matrix.example.org
MATRIX_ACCESS_TOKEN=CHANGE_ME
MATRIX_DEVICE_ID=MESHBOT_WETTER

# Zielraum: Raum-ID (!...) empfohlen; ein Alias (#...) wird beim Start
# aufgelöst und der Bot bricht ab, wenn die Auflösung scheitert.
# Gleicher Raum wie die Wetter-Channel-Bindung der meshcore-matrix-bridge.
WETTER_ROOM=!yourRoomId:matrix.example.org

# Open-Meteo (kein API-Key nötig), Modell z. B. icon_eu / icon_d2 / best_match
OPENMETEO_MODEL=icon_eu

# Location (Default: 33449 Langenberg, Kreis Gütersloh, NRW)
LOCATION_LAT=51.7634
LOCATION_LON=8.3213
LOCATION_NAME=Langenberg

# Schedule (cron-artig, Stunden-Intervall; 6 = 00/06/12/18 UTC)
SCHEDULE_HOURS=6
POST_ON_STARTUP=1

LOG_LEVEL=INFO
# Default: ~/.local/state/meshbot-wetter
# STATE_DIR=
