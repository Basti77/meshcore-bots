# meshbot-wetter environment

# Matrix
MATRIX_HOMESERVER=https://matrix.notlegal.space
MATRIX_USER_ID=@meshwetter:matrix.notlegal.space
MATRIX_ACCESS_TOKEN=CHANGE_ME
MATRIX_DEVICE_ID=MESHBOT_WETTER

# Zielraum: Alias (#...) oder Raum-ID (!...)
# Der bridge-Code routet Matrix→Mesh für genau diesen Raum,
# also gleicher Raum wie die #wetter-Channel-Bindung der Bridge.
WETTER_ROOM=#mesh-wetter:matrix.notlegal.space

# Windy
WINDY_API_KEY=CHANGE_ME
WINDY_MODEL=iconEu

# Location (Default: 33449 Langenberg, Kreis Gütersloh, NRW)
LOCATION_LAT=51.7634
LOCATION_LON=8.3213
LOCATION_NAME=Langenberg

# Schedule (cron-artig, Stunden-Intervall; 6 = 00/06/12/18 UTC)
SCHEDULE_HOURS=6
POST_ON_STARTUP=1

LOG_LEVEL=INFO
STATE_DIR=%h/.local/state/meshbot-wetter
